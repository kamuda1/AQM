# Copy to .env (gitignored) and fill in your real values.
# docker-compose reads .env automatically - no extra flags needed.

# InfluxDB admin credentials for the docker-compose stack.
# INFLUXDB_ADMIN_TOKEN must match INFLUXDB_TOKEN in include/secrets.h.
INFLUXDB_ADMIN_PASSWORD=change-me
INFLUXDB_ADMIN_TOKEN=change-me

# Your Tailscale tailnet hostname for this machine, e.g. from
# `tailscale status --self` or the MagicDNS name in the admin console
# (https://login.tailscale.com/admin/machines). Used to build Grafana's
# external root URL for the /aqm Tailscale Serve route - see README.
TAILSCALE_HOSTNAME=your-machine.tailXXXXX.ts.net
