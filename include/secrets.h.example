#pragma once

// Copy this file to include/secrets.h (which is gitignored) and fill in your
// values. The defaults below line up with the docker-compose.yml stack.

// --- WiFi ---
#define WIFI_SSID     "your-wifi-ssid"
#define WIFI_PASSWORD "your-wifi-password"

// --- Device identity (InfluxDB tag) ---
#define DEVICE_NAME "esp32-aqm"

// --- InfluxDB 2.x ---
// URL must be reachable from the ESP32 on your LAN. Use the host machine's
// LAN IP (e.g. http://192.168.1.50:8086), NOT localhost, since the board is
// a separate device from wherever docker-compose runs.
#define INFLUXDB_URL    "http://192.168.1.50:8086"
#define INFLUXDB_ORG    "aqm"
#define INFLUXDB_BUCKET "aqm"
#define INFLUXDB_TOKEN  "aqm-dev-token-change-me"
